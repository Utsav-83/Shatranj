@startuml
title Java Chess - Core Class Diagram

skinparam classAttributeIconSize 0

package "chess.board" {
  class ChessBoard {
    +setupStartingPosition()
    +clearBoard()
    +movePiece(Move): Piece
    +serializeGame(): String
    +deserializeGame(String)
    +canCastle(boolean, boolean): boolean
  }
  class Position {
    +getRow(): int
    +getColumn(): int
    +isValid(int, int): boolean
  }
  class Square {
    +getPiece(): Piece
    +setPiece(Piece)
    +removePiece(): Piece
  }
}

package "chess.pieces" {
  abstract class Piece {
    +isWhite(): boolean
    +hasMoved(): boolean
    +setMoved(boolean)
    +getSymbol(): String
    +getLegalMoves(Position, ChessBoard): List<Position>
    +getAttackPositions(Position, ChessBoard): List<Position>
  }
  class King
  class Queen
  class Rook
  class Bishop
  class Knight
  class Pawn
}

package "chess.move" {
  class Move
  class MoveGenerator
  class MoveValidator
  class CheckDetector
  class PinDetector
  class GameStateDetector
  class MoveCommand
  class MoveHistory
  interface Command
}

package "chess.gui" {
  class ChessGUI
  class BoardPanel
  class SidePanel
  class MenuPanel
}

package "chess.network" {
  interface ChessService
  interface ChatService
  class ChessServer
  class ChessClient
  class MultiplayerManager
  class ChatThread
}

ChessBoard *-- "64" Square
Square --> Position
Square --> Piece
Piece <|-- King
Piece <|-- Queen
Piece <|-- Rook
Piece <|-- Bishop
Piece <|-- Knight
Piece <|-- Pawn
Piece ..> MoveGenerator
MoveValidator --> MoveGenerator
MoveValidator --> PinDetector
MoveValidator --> CheckDetector
GameStateDetector --> MoveValidator
GameStateDetector --> CheckDetector
MoveCommand ..|> Command
MoveCommand --> ChessBoard
MoveHistory o-- Command
BoardPanel --> ChessBoard
BoardPanel --> MoveValidator
BoardPanel --> MoveHistory
MenuPanel --> ChessBoard
ChessGUI *-- BoardPanel
ChessGUI *-- SidePanel
ChessServer ..|> ChessService
ChessClient --> ChessService
MultiplayerManager --> ChessClient
MultiplayerManager --> ChessServer
ChatThread ..|> ChatService

@enduml
